########## Exec

# Status Bar:
bar {
	swaybar_command waybar
}

exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
# exec lxsession &
exec nm-applet --indicator
exec blueman-applet

# Notification Daemon
exec swaync
# Toggle control center
bindsym --to-code $mod+Shift+n exec swaync-client -t -sw

# GTK Options
set $gnome-schema org.gnome.desktop.interface
exec_always {
    gsettings set $gnome-schema gtk-theme 'rose-pine-gtk'
    gmettings set $gnome-schema icon-theme 'RoséPine'
    #gsettings set $gnome-schema cursor-theme 'BreezeX-RoséPine'
    #gsettings set $gnome-schema cursor-size '20'
    gsettings set $gnome-schema font-name 'Inter 12'
    gsettings set $gnome-schema monospace-font-name 'JetBrains Mono NL 12'
}

# Idle configuration
exec swayidle -w \
    timeout 300 'swaylock -f -c 000000' \
    timeout 600 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"' \
    before-sleep 'swaylock -f -c 000000'

########## Gaps and Borders

# A 10-pixel border around every window.
gaps inner 10
smart_gaps on
smart_borders on

# Removes the title bar of each window.
default_border pixel 3
default_floating_border pixel 3


include /etc/sway/config.d/*

exec dbus-update-activation-environment --systemd DISPLAY XAUTHORITY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec systemctl --user import-environment DISPLAY XAUTHORITY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
