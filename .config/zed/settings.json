// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "buffer_font_size": 20.0,
  "buffer_font_fallbacks": ["Kawkab Mono"],
  "title_bar": {
    "show_menus": true,
  },
  "cli_default_open_behavior": "existing_window",
  "ui_font_size": 22.0,
  "proxy": "",
  "buffer_font_family": "JetBrains Mono NL",
  "agent": {
    "default_model": {
      "provider": "openai",
      "model": "gpt-4",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "edit_predictions": {
    "mode": "subtle",
  },
  "which_key": {
    "enabled": true,
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "relative_line_numbers": "disabled",
  "ui_font_family": ".ZedSans",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "base_keymap": "JetBrains",
  "theme": {
    "mode": "dark",
    "light": "Rosé Pine",
    "dark": "Rosé Pine Moon",
  },
  "experimental.theme_overrides": {
    "background": "#000000",
    "editor.background": "#000000",
    "editor.gutter.background": "#000000",
    "panel.background": "#000000",
    "surface.background": "#000000",
    "terminal.background": "#000000",
    "toolbar.background": "#000000",
    "title_bar.background": "#000000",
    "title_bar.inactive_background": "#000000",
    "status_bar.background": "#000000",
    "tab_bar.background": "#000000",
    "tab.active_background": "#000000",
    "tab.inactive_background": "#000000",
    "scrollbar.track.background": "#000000",
  },
}
