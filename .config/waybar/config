  },
  "pulseaudio": {
    "format": "{icon} {volume}% {format_source}",
    "format-bluetooth": "{icon}пЉ” {volume}% {format_source}",
    "format-bluetooth-muted": "{icon}пЉ” о»Ё {format_source}",
    "format-muted": "о»Ё {format_source}",
    "format-source": "п„° {volume}%",
    "format-source-muted": "п„±",
    "format-icons": {
      "headphone": "пЂҐ",
      "phone": "п‚•",
      "portable": "п‚•",
      "car": "п†№",
      "default": [
        "пЂ¦",
        "пЂ§",
        "пЂЁ"
      ]
    },
    "on-click": "pavucontrol"
  },
  "custom/media": {
    "format": "{}",
    "return-type": "json",
    "max-length": 40,
    "exec": "~/.config/waybar/scripts/playerctl.sh 2> /dev/null",
    "on-click": "playerctl play-pause",
    "on-click-middle": "playerctl previous",
    "on-click-right": "playerctl next",
    "on-scroll-up": "playerctl position 3+",
    "on-scroll-down": "playerctl position 3-",
  }
}
